{
  "name": "commerce-core-api",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test npm run migrate:test && jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "migrate:test": "cross-env NODE_ENV=test knex --knexfile knexfile.ts migrate:latest",
    "test:reset": "cross-env NODE_ENV=test knex --knexfile knexfile.ts migrate:rollback --all && npm run migrate:test",
    "dev": "cross-env NODE_ENV=development tsx watch src/server.ts",
    "dev:prod": "cross-env NODE_ENV=production tsx watch src/server.ts",
    "worker:dev": "cross-env NODE_ENV=development SCHEDULER_DRIVER=cron tsx watch src/workers/app.worker.ts",
    "worker:prod": "cross-env NODE_ENV=production SCHEDULER_DRIVER=cron tsx watch src/workers/app.worker.ts",
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/src/server.js",
    "start:worker": "cross-env SCHEDULER_DRIVER=cron node dist/src/workers/app.worker.js",
    "knex": "cross-env NODE_ENV=development knex --knexfile knexfile.ts",
    "knex:prod": "cross-env NODE_ENV=production knex --knexfile knexfile.ts",
    "seed:super": "cross-env NODE_ENV=development tsx scripts/seed-super.ts",
    "seed:super:prod": "cross-env NODE_ENV=production tsx scripts/seed-super.ts",
    "seed:demo": "cross-env NODE_ENV=development tsx scripts/seed-demo.ts",
    "seed:demo:prod": "cross-env NODE_ENV=production tsx scripts/seed-demo.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.974.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "redis": "^5.11.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "zod": "^4.3.5",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.6",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
